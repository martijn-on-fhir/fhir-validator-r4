{
  "name": "fhir-validator-mx",
  "version": "0.1.7",
  "description": "FHIR R4 resource validator with Dutch nl-core profile support and Nictiz terminologieserver integration",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "config.example.json"
  ],
  "scripts": {
    "build": "webpack --config webpack.config.cjs && tsc --emitDeclarationOnly --outDir dist",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:js": "webpack --config webpack.config.cjs",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/",
    "validate": "ts-node cli/validate.ts",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "fhir",
    "fhir-r4",
    "hl7",
    "validator",
    "healthcare",
    "nl-core",
    "nictiz",
    "snomed",
    "terminology",
    "structuredefinition"
  ],
  "author": "Martijn Schimmel",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martijn-on-fhir/fhir-validator-r4.git"
  },
  "bugs": {
    "url": "https://github.com/martijn-on-fhir/fhir-validator-r4/issues"
  },
  "homepage": "https://github.com/martijn-on-fhir/fhir-validator-r4#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fhirpath": "^3.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jest": "^29.0.0",
    "mongodb": "^7.1.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
